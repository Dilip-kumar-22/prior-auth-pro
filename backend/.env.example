# Application Configuration
ENVIRONMENT="development"
LOG_LEVEL="INFO"
HOST="0.0.0.0"
PORT=8000

# Security
# Generate a secure key using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="your-super-secret-key-change-in-production"
# Comma-separated list or JSON array of allowed origins for CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Database Configuration (PostgreSQL + asyncpg + pgvector)
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/prior_auth_pro"

# Redis Configuration (for ARQ task queue and WebSocket pub/sub)
REDIS_URL="redis://localhost:6379/0"

# FHIR Server Configuration
FHIR_BASE_URL="https://hapi.fhir.org/baseR4"
FHIR_AUTH_TOKEN="optional_fhir_auth_token_here"

# AI / LLM Configuration (Google Gemini)
# Required for RAG Engine (text-embedding-004) and Reasoning Engine
GEMINI_API_KEY="your_google_gemini_api_key_here"